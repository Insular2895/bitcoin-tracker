# Binance Spot API key with read-only permissions only.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Default quote symbols to sync. Use BTCEUR if you buy in EUR.
BINANCE_SYMBOLS=BTCEUR,BTCUSDT

# Put your crypto tracking address(es) right after the equals sign.
# Example format: BTC_WATCH_ADDRESSES=<your-btc-address>,<another-btc-address>
# Keep real wallet addresses in .env only, never in README or committed files.
BTC_WATCH_ADDRESSES=

# Local database and export paths.
TRACKER_DB=data/portfolio.sqlite
EXPORT_DIR=exports

# Public Bitcoin API. You can later replace it with your own mempool instance.
MEMPOOL_API_BASE=https://mempool.space/api
